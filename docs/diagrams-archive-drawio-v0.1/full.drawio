  <diagram id="d08" name="SSO Security Flow">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Face Detection MLOps — SSO Security Flow (12-step OIDC via Keycloak)" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1840" height="40" as="geometry" />
        </mxCell>
        <mxCell id="user" value="User&#10;(browser)" style="shape=actor;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="480" width="60" height="80" as="geometry" />
        </mxCell>
        <mxCell id="istio-ns" value="istio-system" style="swimlane;fontSize=14;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="240" y="100" width="260" height="880" as="geometry" />
        </mxCell>
        <mxCell id="gw-istio" value="Istio Gateway&#10;(entry point)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;" vertex="1" parent="istio-ns">
          <mxGeometry x="30" y="440" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="auth-ns" value="auth-ns" style="swimlane;fontSize=14;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="560" y="100" width="320" height="880" as="geometry" />
        </mxCell>
        <mxCell id="oauth2-proxy" value="OAuth2 Proxy&#10;(session check)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;" vertex="1" parent="auth-ns">
          <mxGeometry x="40" y="100" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="keycloak" value="Keycloak&#10;(OIDC Identity Provider)&#10;realm: face-detect&#10;clients: *-webapp&#10;roles: 6 personas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;" vertex="1" parent="auth-ns">
          <mxGeometry x="40" y="260" width="240" height="200" as="geometry" />
        </mxCell>
        <mxCell id="kc-db" value="PostgreSQL&#10;(Keycloak backing)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;dashed=1;" vertex="1" parent="auth-ns">
          <mxGeometry x="40" y="520" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="app-ns" value="target app (any ns)" style="swimlane;fontSize=14;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontStyle=1;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="940" y="100" width="320" height="880" as="geometry" />
        </mxCell>
        <mxCell id="app" value="Protected App&#10;e.g. Grafana /&#10;Airflow /&#10;Kibana /&#10;MLflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;" vertex="1" parent="app-ns">
          <mxGeometry x="40" y="340" width="240" height="200" as="geometry" />
        </mxCell>
        <mxCell id="steps" value="12-step OIDC flow" style="text;html=1;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1320" y="100" width="480" height="30" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="1. User requests app.face-detect.dev&#10;2. Istio Gateway intercepts&#10;3. OAuth2 Proxy checks session cookie&#10;4. No session → redirect /auth endpoint&#10;5. Keycloak shows login page (2FA)&#10;6. User submits credentials" style="text;html=1;align=left;fontSize=11;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1320" y="160" width="560" height="200" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="7. Keycloak issues authorization code&#10;8. Callback → OAuth2 Proxy exchanges code → JWT&#10;9. Proxy sets wildcard session cookie *.face-detect.dev&#10;10. Proxy redirects browser back to /app&#10;11. EnvoyFilter validates JWT (RS256) on each request&#10;12. Forward request with X-Auth-User claims header" style="text;html=1;align=left;fontSize=11;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1320" y="380" width="560" height="200" as="geometry" />
        </mxCell>
        <mxCell id="note" value="Native OIDC apps: Grafana, Airflow, MLflow, Kubeflow, DataHub, MinIO&#10;OAuth2 Proxy apps: Kibana, Jaeger, Spark UI, Flink UI, Langfuse" style="text;html=1;align=left;fontSize=10;fontColor=#666666;fontStyle=2;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1320" y="620" width="560" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="1. GET /app" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="user" target="gw-istio">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="2. Route" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="gw-istio" target="oauth2-proxy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="3-5. Redirect /auth&#10;+ login page" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="oauth2-proxy" target="keycloak">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="7. Auth code" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="keycloak" target="oauth2-proxy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="Lookup users/roles" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="keycloak" target="kc-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="8-9. Exchange code&#10;+ set cookie" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="oauth2-proxy" target="keycloak">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="10. Redirect&#10;12. Forward with claims" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="oauth2-proxy" target="app">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="v0.1 | 2026-04-19 | longhd" style="text;html=1;align=right;verticalAlign=middle;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="1040" width="1840" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
